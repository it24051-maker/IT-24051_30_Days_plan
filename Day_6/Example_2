class Vehicle {
    int speed;

    void setSpeed(int s) {
        speed = s;
    }
}

class Car extends Vehicle {
    void show() {
        System.out.println("Speed: " + speed + " km/h");
    }
}

public class Main {
    public static void main(String[] args) {
        Car c1 = new Car();
        c1.setSpeed(120);
        c1.show();
    }
}
