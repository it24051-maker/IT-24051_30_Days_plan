class Student {
    private String name;
    private int marks;

    public void setName(String n) {
        name = n;
    }

    public void setMarks(int m) {
        marks = m;
    }

    public String getName() {
        return name;
    }

    public int getMarks() {
        return marks;
    }

    public void show() {
        System.out.println("Name: " + name);
        System.out.println("Marks: " + marks);
    }
}

public class Main {
    public static void main(String[] args) {
        Student s1 = new Student();
        s1.setName("Shawon");
        s1.setMarks(85);
        s1.show();
    }
}
