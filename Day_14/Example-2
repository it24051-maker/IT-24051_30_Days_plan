// TreeMap Example

import java.util.TreeMap;

public class MapExample2 {
    public static void main(String[] args) {

        TreeMap<String, Integer> marks = new TreeMap<>();

        marks.put("Math", 80);
        marks.put("English", 75);
        marks.put("ICT", 90);

        System.out.println(marks);

        System.out.println("ICT Marks: " + marks.get("ICT"));

        marks.put("Math", 95);

        System.out.println("Updated Map: " + marks);
    }
}
